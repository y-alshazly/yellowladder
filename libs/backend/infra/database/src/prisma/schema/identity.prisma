// Yellow Ladder — Identity domain
//
// Owns:
//   - Company           (tenancy root — id IS company_id)
//   - User              (platform-global — NO company_id column, linked via nullable FK)
//   - UserDeviceInfo    (push tokens, device metadata — platform-global)
//   - OtpRecord         (5-min TTL, SHA-256 hashed code)
//   - PasswordResetToken (1-hour TTL, SHA-256 hashed, single-use, latest-only)
//   - EmailVerificationToken (24-hour TTL, SHA-256 hashed, latest-only)
//                        NOTE: Legacy Tappd used OTP-only for email verification.
//                        This table is declared for API/product symmetry with the
//                        other single-use token tables and to keep the door open
//                        for a future link-based flow. Feature 01 does not write
//                        to it — OTP is the canonical path (architect decided).
//   - RefreshTokenRecord (7-day TTL, SHA-256 hashed, rotation + reuse detection)
//   - CompanyPrimaryContact (snapshot of PSC or manual contact at onboarding)
//   - BusinessType / BusinessCategory / AnnualTurnoverBand / PaymentMethod
//                        (4 platform-global config enum tables)
//
// Tenancy:
//   - Company      : RLS on `id = current_setting('app.current_company')::uuid`
//                    (root table — row equals its own tenancy boundary)
//   - CompanyPrimaryContact : RLS on `company_id`
//   - All other tables in this file are PLATFORM-GLOBAL — no company_id,
//     no RLS. Data integrity is enforced via FK + service-layer auth.

// -----------------------------------------------------------------------------
// Company — tenancy root
// -----------------------------------------------------------------------------
model Company {
  id                              String    @id @default(uuid()) @db.Uuid

  // Core naming
  name                            String    @map("name") @db.VarChar(255)
  tradingName                     String?   @map("trading_name") @db.VarChar(255)

  // Branch on businessType (LIMITED_COMPANY | SELF_EMPLOYED). Stored as code
  // string — the row in BusinessType owns the canonical label. We keep both
  // the FK and a denormalised `business_type_code` for hot-path reads during
  // onboarding so the wizard does not need a JOIN.
  businessTypeCode                String    @map("business_type_code") @db.VarChar(64)
  businessTypeId                  String    @map("business_type_id") @db.Uuid
  businessType                    BusinessType @relation(fields: [businessTypeId], references: [id])

  // Business profile (wizard step 1 — collected for both branches)
  businessCategoryId              String    @map("business_category_id") @db.Uuid
  businessCategory                BusinessCategory @relation(fields: [businessCategoryId], references: [id])

  paymentMethodId                 String    @map("payment_method_id") @db.Uuid
  paymentMethod                   PaymentMethod @relation(fields: [paymentMethodId], references: [id])

  annualTurnoverBandId            String    @map("annual_turnover_band_id") @db.Uuid
  annualTurnoverBand              AnnualTurnoverBand @relation(fields: [annualTurnoverBandId], references: [id])

  vatRegistered                   Boolean   @default(false) @map("vat_registered")
  // Unique when present. Postgres treats NULLs as distinct in unique indexes,
  // so multiple companies without a VAT number are allowed; two with the same
  // non-NULL value are not. The migration installs the index as a plain
  // (non-partial) UNIQUE index — Prisma cannot express WHERE-predicated
  // indexes, so a full unique was picked to keep the Prisma model the source
  // of truth and avoid drift on the next `prisma migrate dev`.
  vatNumber                       String?   @unique(map: "companies_vat_number_key") @map("vat_number") @db.VarChar(32)

  // Limited-company branch (nullable — empty for SELF_EMPLOYED).
  // Same unique-with-NULL rationale as vatNumber above.
  registrationNumber              String?   @unique(map: "companies_registration_number_key") @map("registration_number") @db.VarChar(16)
  incorporationDate               DateTime? @map("incorporation_date") @db.Date

  // Registered address (both branches)
  registeredAddressLine1          String    @map("registered_address_line1") @db.VarChar(255)
  registeredAddressLine2          String?   @map("registered_address_line2") @db.VarChar(255)
  registeredAddressCity           String    @map("registered_address_city") @db.VarChar(128)
  registeredAddressRegion         String?   @map("registered_address_region") @db.VarChar(128)
  registeredAddressPostcode       String    @map("registered_address_postcode") @db.VarChar(16)
  registeredAddressCountryCode    String    @map("registered_address_country_code") @db.Char(2)

  // Self-employed branch (nullable — empty for LIMITED_COMPANY)
  selfEmployedFirstName           String?   @map("self_employed_first_name") @db.VarChar(120)
  selfEmployedLastName            String?   @map("self_employed_last_name") @db.VarChar(120)
  selfEmployedJobPosition         String?   @map("self_employed_job_position") @db.VarChar(120)
  selfEmployedDateOfBirth         DateTime? @map("self_employed_date_of_birth") @db.Date
  selfEmployedStoreIsSameAddress  Boolean?  @map("self_employed_store_is_same_address")

  // Audit / legal
  authorisationConfirmedAt        DateTime  @map("authorisation_confirmed_at") @db.Timestamptz
  idempotencyKey                  String    @map("idempotency_key") @db.Uuid

  // Soft delete / status (per invariant: companies are deactivated, never deleted)
  isActive                        Boolean   @default(true) @map("is_active")

  createdAt                       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  users                           User[]
  primaryContacts                 CompanyPrimaryContact[]

  @@unique([idempotencyKey])
  @@index([businessTypeId])
  @@index([businessCategoryId])
  @@index([paymentMethodId])
  @@index([annualTurnoverBandId])
  @@index([isActive])
  @@map("companies")
}

// -----------------------------------------------------------------------------
// User — PLATFORM-GLOBAL (NO company_id column, NO RLS)
// -----------------------------------------------------------------------------
model User {
  id                     String    @id @default(uuid()) @db.Uuid

  // Identity
  email                  String    @map("email") @db.VarChar(320)
  emailNormalised        String    @map("email_normalised") @db.VarChar(320) // lower(email) for case-insensitive unique
  passwordHash           String    @map("password_hash") @db.VarChar(255)    // bcrypt cost >= 12

  // Profile
  firstName              String?   @map("first_name") @db.VarChar(120)
  lastName               String?   @map("last_name") @db.VarChar(120)
  phoneE164              String    @map("phone_e164") @db.VarChar(20)
  phoneCountryCode       String    @map("phone_country_code") @db.VarChar(4)   // ISO 3166-1 alpha-2 (e.g. "GB")
  countryCode            String    @map("country_code") @db.Char(2)            // "Where are you based?" from register form
  profilePhotoUrl        String?   @map("profile_photo_url") @db.VarChar(2048)

  // Role — stored as string (no Prisma enum per project rules)
  // Valid values: SUPER_ADMIN | COMPANY_ADMIN | SHOP_MANAGER | EMPLOYEE | CUSTOMER
  role                   String    @default("COMPANY_ADMIN") @map("role") @db.VarChar(32)

  // Onboarding state — stored as string (no Prisma enum)
  // Valid values: PHASE_A_REGISTERED | PHASE_B_VERIFIED | PHASE_C_COMPLETED
  onboardingPhase        String    @default("PHASE_A_REGISTERED") @map("onboarding_phase") @db.VarChar(32)

  // Status — stored as string (no Prisma enum)
  // Valid values: ACTIVE | SUSPENDED | DELETED
  status                 String    @default("ACTIVE") @map("status") @db.VarChar(16)

  // Verification + consent
  emailVerifiedAt        DateTime? @map("email_verified_at") @db.Timestamptz
  termsAcceptedAt        DateTime? @map("terms_accepted_at") @db.Timestamptz
  passwordChangedAt      DateTime? @map("password_changed_at") @db.Timestamptz

  // Tenancy link — NULLABLE during Phase A/B, populated at end of Phase C.
  // Platform-global: this is a FK, NOT an RLS column.
  companyId              String?   @map("company_id") @db.Uuid
  company                Company?  @relation(fields: [companyId], references: [id])

  // Timestamps
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt              DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  deviceInfos            UserDeviceInfo[]
  otpRecords             OtpRecord[]
  passwordResetTokens    PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  refreshTokenRecords    RefreshTokenRecord[]

  @@unique([emailNormalised])
  @@index([companyId])
  @@index([phoneE164])
  @@index([onboardingPhase, status])
  @@index([createdAt])
  @@map("users")
}

// -----------------------------------------------------------------------------
// UserDeviceInfo — platform-global (tied to User; User is platform-global)
// -----------------------------------------------------------------------------
model UserDeviceInfo {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  deviceId          String   @map("device_id") @db.VarChar(128)
  // Platform: ios | android | web (stored as string per no-enum rule)
  platform          String   @map("platform") @db.VarChar(16)
  osVersion         String   @map("os_version") @db.VarChar(64)
  appVersion        String   @map("app_version") @db.VarChar(32)
  model             String?  @map("model") @db.VarChar(128)
  fcmToken          String?  @map("fcm_token") @db.VarChar(512)

  lastSeenAt        DateTime @default(now()) @map("last_seen_at") @db.Timestamptz
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([userId, deviceId])
  @@index([userId])
  @@index([fcmToken])
  @@map("user_device_info")
}

// -----------------------------------------------------------------------------
// OtpRecord — email-based one-time password (5-min TTL, SHA-256 hashed)
// -----------------------------------------------------------------------------
model OtpRecord {
  id           String    @id @default(uuid()) @db.Uuid

  // FK to User — userId REQUIRED because OTP is always post-register per
  // architect's state machine. Duplicated email column kept for rate-window
  // lookups without a join.
  userId       String    @map("user_id") @db.Uuid
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  email        String    @map("email") @db.VarChar(320)

  // Purpose — stored as string (no Prisma enum)
  // Valid values: EMAIL_VERIFICATION (only value used in Feature 01)
  purpose      String    @map("purpose") @db.VarChar(32)

  // 64 hex chars = SHA-256 digest of the 6-digit code. Raw code never stored.
  codeHash     String    @map("code_hash") @db.Char(64)

  attempts     Int       @default(0) @map("attempts")
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz
  consumedAt   DateTime? @map("consumed_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId, purpose, createdAt(sort: Desc)])
  @@index([email, createdAt(sort: Desc)])
  @@index([expiresAt])
  @@map("otp_records")
}

// -----------------------------------------------------------------------------
// PasswordResetToken — 1-hour TTL, single-use, SHA-256 hashed, latest-only
// -----------------------------------------------------------------------------
model PasswordResetToken {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash    String    @map("token_hash") @db.Char(64)

  expiresAt    DateTime  @map("expires_at") @db.Timestamptz
  consumedAt   DateTime? @map("consumed_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@unique([tokenHash])
  @@index([userId, consumedAt, createdAt(sort: Desc)])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// -----------------------------------------------------------------------------
// EmailVerificationToken — 24-hour TTL, latest-only, SHA-256 hashed
// NOTE: Feature 01 uses OTP for email verification (see OtpRecord). This table
// is declared for future link-based verification (Feature 2+ enterprise invite,
// etc.). It is NOT populated by Feature 01 code. Keeping the table in the
// schema now avoids a later migration that would be harder once data exists.
// -----------------------------------------------------------------------------
model EmailVerificationToken {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash    String    @map("token_hash") @db.Char(64)

  expiresAt    DateTime  @map("expires_at") @db.Timestamptz
  consumedAt   DateTime? @map("consumed_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@unique([tokenHash])
  @@index([userId, createdAt(sort: Desc)])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

// -----------------------------------------------------------------------------
// RefreshTokenRecord — 7-day TTL, rotation, reuse detection
//
// One row per active refresh session. SHA-256 hashed. `rotatedAt IS NOT NULL`
// OR `revoked = true` with a matching incoming hash = reuse detected → call
// revokeAllForUser(userId).
//
// Platform-global — no RLS. Backend-engineer owns the rotation/reuse logic.
// -----------------------------------------------------------------------------
model RefreshTokenRecord {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash      String    @map("token_hash") @db.Char(64)
  csrfHash       String    @map("csrf_hash") @db.Char(64)

  userAgent      String?   @map("user_agent") @db.VarChar(512)
  ipAddress      String?   @map("ip_address") @db.VarChar(64)

  rotatedAt      DateTime? @map("rotated_at") @db.Timestamptz
  revoked        Boolean   @default(false) @map("revoked")
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@unique([tokenHash])
  @@index([userId, expiresAt])
  @@index([userId, revoked, rotatedAt])
  @@map("refresh_token_records")
}

// -----------------------------------------------------------------------------
// CompanyPrimaryContact — snapshot of the PSC or manual contact selected at
// onboarding. Multi-tenant (company_id) → RLS enforced.
// -----------------------------------------------------------------------------
model CompanyPrimaryContact {
  id           String   @id @default(uuid()) @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Source: PSC | MANUAL (stored as string — no Prisma enum)
  source       String   @map("source") @db.VarChar(16)
  // Upstream Companies House PSC identifier when source = PSC; NULL when MANUAL
  pscId        String?  @map("psc_id") @db.VarChar(128)

  firstName    String   @map("first_name") @db.VarChar(120)
  lastName     String   @map("last_name") @db.VarChar(120)
  jobPosition  String   @map("job_position") @db.VarChar(120)
  phoneE164    String?  @map("phone_e164") @db.VarChar(20)
  email        String?  @map("email") @db.VarChar(320)

  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([companyId])
  @@map("company_primary_contacts")
}

// =============================================================================
// Config enum tables (4) — platform-global reference data
// =============================================================================

// -----------------------------------------------------------------------------
// BusinessType — LIMITED_COMPANY | SELF_EMPLOYED
// -----------------------------------------------------------------------------
model BusinessType {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @map("code") @db.VarChar(64)
  labelEn     String   @map("label_en") @db.VarChar(255)
  labelDe     String   @map("label_de") @db.VarChar(255)
  labelFr     String   @map("label_fr") @db.VarChar(255)
  labelKey    String   @map("label_key") @db.VarChar(128) // i18n key for react-i18next
  sortOrder   Int      @default(0) @map("sort_order")
  active      Boolean  @default(true) @map("active")

  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  companies   Company[]

  @@unique([code])
  @@index([active, sortOrder])
  @@map("business_types")
}

// -----------------------------------------------------------------------------
// BusinessCategory — restaurant categories (Food & Drinks, Retail, etc.)
// -----------------------------------------------------------------------------
model BusinessCategory {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @map("code") @db.VarChar(64)
  labelEn     String   @map("label_en") @db.VarChar(255)
  labelDe     String   @map("label_de") @db.VarChar(255)
  labelFr     String   @map("label_fr") @db.VarChar(255)
  labelKey    String   @map("label_key") @db.VarChar(128)
  iconName    String?  @map("icon_name") @db.VarChar(64)
  sortOrder   Int      @default(0) @map("sort_order")
  active      Boolean  @default(true) @map("active")

  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  companies   Company[]

  @@unique([code])
  @@index([active, sortOrder])
  @@map("business_categories")
}

// -----------------------------------------------------------------------------
// AnnualTurnoverBand — GBP turnover bracket options
// -----------------------------------------------------------------------------
model AnnualTurnoverBand {
  id            String   @id @default(uuid()) @db.Uuid
  code          String   @map("code") @db.VarChar(64)
  labelEn       String   @map("label_en") @db.VarChar(255)
  labelDe       String   @map("label_de") @db.VarChar(255)
  labelFr       String   @map("label_fr") @db.VarChar(255)
  labelKey      String   @map("label_key") @db.VarChar(128)
  minAmountGbp  Int      @map("min_amount_gbp")
  maxAmountGbp  Int?     @map("max_amount_gbp") // NULL for top band
  sortOrder     Int      @default(0) @map("sort_order")
  active        Boolean  @default(true) @map("active")

  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  companies     Company[]

  @@unique([code])
  @@index([active, sortOrder])
  @@map("annual_turnover_bands")
}

// -----------------------------------------------------------------------------
// PaymentMethod — payment method preferences (Permanent / On-the-go / Both)
// -----------------------------------------------------------------------------
model PaymentMethod {
  id             String   @id @default(uuid()) @db.Uuid
  code           String   @map("code") @db.VarChar(64)
  labelEn        String   @map("label_en") @db.VarChar(255)
  labelDe        String   @map("label_de") @db.VarChar(255)
  labelFr        String   @map("label_fr") @db.VarChar(255)
  labelKey       String   @map("label_key") @db.VarChar(128)
  descriptionEn  String?  @map("description_en") @db.VarChar(512)
  descriptionDe  String?  @map("description_de") @db.VarChar(512)
  descriptionFr  String?  @map("description_fr") @db.VarChar(512)
  sortOrder      Int      @default(0) @map("sort_order")
  active         Boolean  @default(true) @map("active")

  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  companies      Company[]

  @@unique([code])
  @@index([active, sortOrder])
  @@map("payment_methods")
}
